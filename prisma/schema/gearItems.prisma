model GearItems{

  id String @id @default(uuid())
  providerId String
  provider Provider @relation(fields: [providerId], references: [id],onDelete: Cascade)
  category Category @default(fitness)

  name String

  description String

  image String?
  stock Int

  condition String?

  rentalPricePerDay Float
  brand String
  availability GearAvailability @default(AVAILABLE)
  reviews Reviews[]
  rentalOrder RentalOrder[]


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

@@map("gearitems")
}