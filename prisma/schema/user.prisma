model User{

  id String @id @default(uuid())
  name String 
  email String @unique 
  password String
  phone String? @unique
  role role @default(Customer)
  profile_photo String?
  address String?
  status User_Status @default(ACTIVE)
  Provider Provider?
  Customer Customer?
  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt




  @@map("user")
}