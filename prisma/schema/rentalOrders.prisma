model RentalOrder{

  id String @id @default(uuid())

  rentalStatus Rental_Status @default(PLACED)
  gearItemId String
  gearItem GearItems @relation(fields: [gearItemId], references: [id])
  customerId String
  customer Customer @relation(fields: [customerId], references: [id])   
  payment Payment? 

  startDate DateTime

endDate DateTime

  totalAmount Float


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt




  @@map("rentalorder")
}