{
  "name": "gearup",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsup src/server.ts --watch --out-dir api --onSuccess \"node api/server.js\"",
    "build": "prisma generate && tsup src/server.ts --format esm --clean --out-dir api",
    "vercel-build": "prisma generate && tsup src/server.ts --format esm --clean --out-dir api",
    "start": "node api/server.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "stripe": "^22.3.0",
    "tsx": "^4.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}